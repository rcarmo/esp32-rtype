# PlatformIO / ESP-IDF build output
.pio/
build/
sdkconfig
sdkconfig.old
sdkconfig.*-rtype
dependencies.lock

# Tracked managed-component allowlist. Other component-manager downloads are generated.
managed_components/*
!managed_components/espressif__esp_lcd_ili9341/
!managed_components/espressif__esp_lcd_ili9341/**
!managed_components/espressif__cmake_utilities/
!managed_components/espressif__cmake_utilities/**

# Local ROM drop directory. Only placeholders are tracked.
roms/*
!roms/.gitkeep
!roms/README.md

# Generated project artifacts: packed ROMs, FAT images, camera captures, host frames.
artifacts/

# Local/editor/cache noise
.DS_Store
__pycache__/
*.py[cod]
*~
*.swp
